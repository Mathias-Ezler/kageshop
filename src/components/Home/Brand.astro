---
interface Props {
  title?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  image1Src?: string;
  image1Alt?: string;
  image2Src?: string;
  image2Alt?: string;
}

const {
  title       = "Diseño. Pulido. Rendimiento.",
  description = "Kage Store elimina lo innecesario, centrándose puramente en lo que eleva tu experiencia digital. Creemos que las herramientas profesionales no solo deben funcionar impecablemente, sino también inspirar visualmente. Cada artículo es seleccionado con obsesión por el detalle.",
  ctaLabel    = "Conocer Más",
  ctaHref     = "/nosotros",
  image1Src   = "/img/fondo.jpg",
  image1Alt   = "Componentes PC",
  image2Src   = "/img/fondo2.jpg",
  image2Alt   = "Hardware de alto rendimiento",
} = Astro.props;
---

<section class="w-full bg-white px-4 sm:px-6 lg:px-8 py-20">
  <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center gap-12 lg:gap-20">

    <!-- Left: staggered images -->
    <div class="relative flex-shrink-0 w-full md:w-auto flex justify-center">
      <div class="relative" style="width: 340px; height: 280px;">

        <!-- Back image (taller, left) -->
        <div class="absolute left-0 top-0 w-44 h-64 overflow-hidden bg-gray-200 shadow-md">
          {image1Src ? (
            <img src={image1Src} alt={image1Alt} class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full" style="background-image: repeating-conic-gradient(#c8cfd8 0% 25%, #dde1e8 0% 50%); background-size: 20px 20px;" />
          )}
        </div>

        <!-- Front image (shorter, overlapping right) -->
        <div class="absolute right-0 top-8 w-44 h-56 overflow-hidden bg-gray-300 shadow-lg">
          {image2Src ? (
            <img src={image2Src} alt={image2Alt} class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full" style="background-image: repeating-conic-gradient(#b0b8c4 0% 25%, #c8cfd8 0% 50%); background-size: 20px 20px;" />
          )}
        </div>

      </div>
    </div>

    <!-- Right: text -->
    <div class="flex flex-col gap-6 max-w-md">
      <h2 class="text-3xl sm:text-4xl font-extralight tracking-tight text-gray-900 uppercase leading-tight">
        {title}
      </h2>

      <p class="text-sm text-gray-500 leading-relaxed">
        {description}
      </p>

      <a
        href={ctaHref}
        class="self-start inline-flex items-center justify-center bg-violet-600 hover:bg-violet-700 active:bg-violet-800 text-white text-xs font-semibold tracking-widest uppercase px-10 py-4 transition-colors duration-200"
      >
        {ctaLabel}
      </a>
    </div>

  </div>
</section>
