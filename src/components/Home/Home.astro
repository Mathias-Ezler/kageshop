---
const imageAlt = "Producto destacado";
---

<section class="w-full min-h-[90vh] flex flex-col md:flex-row">

  <!-- Left: Text content -->
  <div class="flex flex-1 flex-col justify-center px-8 sm:px-12 lg:px-20 py-20 bg-white">
    <div class="max-w-lg">
      <h1 class="leading-none tracking-tight mb-6">
        <span class="block text-5xl sm:text-6xl lg:text-7xl font-light text-black uppercase">
          Precisión
        </span>
        <span class="block text-5xl sm:text-6xl lg:text-7xl font-black text-black uppercase">
          Redefinida.
        </span>
      </h1>

      <p class="text-xs sm:text-sm font-medium tracking-widest text-gray-500 uppercase leading-relaxed mb-10 max-w-xs">
        Software y periféricos de alta gama diseñados para el rendimiento absoluto.
        Seleccionados exclusivamente para el profesional moderno.
      </p>

      <a
        href="/productos"
        class="inline-flex items-center gap-3 bg-violet-600 hover:bg-violet-700 active:bg-violet-800 text-white text-xs font-semibold tracking-widest uppercase px-6 py-3 transition-colors duration-200"
      >
        Explorar Colección

        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 8l4 4m0 0l-4 4m4-4H3"
          />
        </svg>
      </a>
    </div>
  </div>

  <!-- Right: Image -->
  <div class="flex-1 min-h-[50vh] md:min-h-0 relative overflow-hidden">
    <img
      src="/img/fondo.jpg"
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover"
    />
  </div>

</section>

<hr class="w-full border-0 border-t border-gray-300" />