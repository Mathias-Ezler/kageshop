---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  items?: FAQItem[];
  viewAllHref?: string;
  viewAllLabel?: string;
}

const defaultItems: FAQItem[] = [
  {
    question: "¿Cuál es el tiempo de entrega?",
    answer:
      "Todos nuestros artículos en stock se procesan en 24 horas. Los artículos en pre-orden se envían en 2-4 semanas directamente desde nuestros fabricantes.",
  },
  {
    question: "¿Ofrecen envío internacional?",
    answer:
      "Sí, realizamos envíos a toda Latinoamérica y varios países de Europa. Los tiempos y costos varían según el destino.",
  },
  {
    question: "¿Cómo funciona la pre-orden?",
    answer:
      "Al realizar una pre-orden, reservas tu unidad antes de que llegue al stock. Se cobra el 100% al momento del pedido y recibirás tu producto en cuanto esté disponible.",
  },
  {
    question: "Política de garantía",
    answer:
      "Todos nuestros productos cuentan con garantía mínima de 12 meses. En caso de fallas de fabricación, gestionamos el proceso de cambio o devolución sin costo adicional.",
  },
];

const {
  title        = "Preguntas Comunes",
  items        = defaultItems,
  viewAllHref  = "/preguntas-frecuentes",
  viewAllLabel = "Ver Todas las FAQs",
} = Astro.props;
---

<section class="w-full bg-white px-4 sm:px-6 lg:px-8 py-20 border-t border-gray-100">
  <div class="mx-auto max-w-2xl">

    <!-- Section label -->
    <p class="text-center text-xs font-semibold tracking-[0.3em] text-gray-400 uppercase mb-10">
      {title}
    </p>

    <!-- Accordion -->
    <div class="divide-y divide-gray-200" id="faq-list">
      {items.map((item, i) => (
        <div class="faq-item py-5">
          <button
            class="faq-trigger w-full flex items-center justify-between gap-4 text-left group"
            aria-expanded={i === 0 ? "true" : "false"}
          >
            <span class="text-xs font-semibold tracking-widest text-gray-800 uppercase group-hover:text-black transition-colors">
              {item.question}
            </span>
            <!-- Chevron -->
            <span class="faq-icon shrink-0 text-gray-400 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </button>

          <!-- Answer -->
          <div class={`faq-body overflow-hidden transition-all duration-300 ${i === 0 ? "max-h-96 mt-4" : "max-h-0"}`}>
            <p class="text-sm text-gray-500 leading-relaxed">
              {item.answer}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- View all button -->
    <div class="flex justify-center mt-12">
      <a
        href={viewAllHref}
        class="inline-flex items-center justify-center bg-violet-600 hover:bg-violet-700 active:bg-violet-800 text-white text-xs font-semibold tracking-widest uppercase px-10 py-4 transition-colors duration-200"
      >
        {viewAllLabel}
      </a>
    </div>

  </div>
</section>

<script>
  const items = document.querySelectorAll(".faq-item");

  items.forEach((item) => {
    const trigger = item.querySelector<HTMLButtonElement>(".faq-trigger")!;
    const body    = item.querySelector<HTMLElement>(".faq-body")!;
    const icon    = item.querySelector<HTMLElement>(".faq-icon")!;

    trigger.addEventListener("click", () => {
      const isOpen = trigger.getAttribute("aria-expanded") === "true";

      // Close all
      items.forEach((other) => {
        const otherTrigger = other.querySelector<HTMLButtonElement>(".faq-trigger")!;
        const otherBody    = other.querySelector<HTMLElement>(".faq-body")!;
        const otherIcon    = other.querySelector<HTMLElement>(".faq-icon")!;
        otherTrigger.setAttribute("aria-expanded", "false");
        otherBody.classList.remove("max-h-96", "mt-4");
        otherBody.classList.add("max-h-0");
        otherIcon.style.transform = "rotate(0deg)";
      });

      // Open clicked (if it was closed)
      if (!isOpen) {
        trigger.setAttribute("aria-expanded", "true");
        body.classList.remove("max-h-0");
        body.classList.add("max-h-96", "mt-4");
        icon.style.transform = "rotate(180deg)";
      }
    });
  });
</script>
